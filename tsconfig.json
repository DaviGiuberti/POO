{
  "compilerOptions": {
    "types": ["node"], 
    "moduleResolution": "node16",
    "module": "node16", // 👈 Alterado aqui de commonjs para node16
    "outDir": "./dist",
    "target": "ES2022",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  }
}