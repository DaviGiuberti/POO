{
  "compilerOptions": {
    "types": ["node"],
    "moduleResolution": "node16",
    "module": "node16",
    "outDir": "./dist",
    "target": "ES2022",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["index.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "vitest.config.ts"]
}